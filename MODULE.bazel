exports_files(["img/reference-dmg.png"])
""",
    integrity = "sha256-xZiN2VpAAbk+mM+K74WStZGzWnoI/IsMwqSKwOPl6g4=",
    strip_prefix = "dmg-acid2-master",
    url = "https://github.com/mattcurrie/dmg-acid2/archive/refs/heads/master.zip",
)

http_file(
    name = "dmg_acid2_rom",
    downloaded_file_path = "dmg-acid2.gb",
    integrity = "sha256-Rk4Ut9Quf+6gt+3kK+cHHciJE/dbn/pEQplCS2PR3/E=",
